{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "config": {
      "language": "python",
      "pythonVersion": "3.11"
    }
  },
  "deploy": {
    "startCommand": "python backend/server.py",
    "healthcheckPath": "/api/status",
    "healthcheckTimeout": 30,
    "restartPolicyType": "on_failure"
  }
}
